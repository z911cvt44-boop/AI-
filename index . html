<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Fitness Coach — مدرّبك الذكي</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/control_utils/control_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils/drawing_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/pose/pose.js" crossorigin="anonymous"></script>

<style>
:root {
  --bg: #080810;
  --surface: #0f0f1e;
  --surface2: #161628;
  --border: rgba(255,255,255,0.08);
  --purple: #6C5CE7;
  --teal: #00CEC9;
  --green: #00C896;
  --red: #FF5555;
  --amber: #FFB400;
  --text: #FFFFFF;
  --text2: rgba(255,255,255,0.5);
  --text3: rgba(255,255,255,0.25);
  --font: 'Cairo', sans-serif;
  --mono: 'Space Mono', monospace;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ===== HEADER ===== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  border-bottom: 1px solid var(--border);
  background: rgba(8,8,16,0.95);
  backdrop-filter: blur(12px);
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--purple), var(--teal));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.logo-text {
  font-size: 18px;
  font-weight: 900;
  background: linear-gradient(90deg, var(--purple), var(--teal));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.header-status {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--text2);
  font-family: var(--mono);
}

.status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--text3);
}

.status-dot.active {
  background: var(--green);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%,100% { opacity: 1; box-shadow: 0 0 0 0 rgba(0,200,150,0.4); }
  50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(0,200,150,0); }
}

/* ===== MAIN LAYOUT ===== */
.main {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 20px;
  padding: 20px 24px;
  max-width: 1400px;
  margin: 0 auto;
  align-items: start;
}

@media (max-width: 900px) {
  .main { grid-template-columns: 1fr; }
  .sidebar { order: 2; }
  .camera-col { order: 1; }
}

/* ===== CAMERA AREA ===== */
.camera-col {}

.camera-wrap {
  position: relative;
  background: #000;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid var(--border);
  aspect-ratio: 4/3;
}

#videoElement {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transform: scaleX(-1);
}

#outputCanvas {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  transform: scaleX(-1);
}

.camera-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  background: var(--surface);
}

.camera-placeholder-icon {
  font-size: 56px;
  opacity: 0.3;
}

.camera-placeholder p {
  color: var(--text2);
  font-size: 14px;
  text-align: center;
  max-width: 220px;
  line-height: 1.6;
}

/* Camera overlays */
.cam-top {
  position: absolute;
  top: 0; left: 0; right: 0;
  padding: 14px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(180deg, rgba(0,0,0,0.75) 0%, transparent 100%);
  pointer-events: none;
}

.rec-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--red);
  font-family: var(--mono);
  font-weight: 700;
  opacity: 0;
  transition: opacity 0.3s;
}

.rec-badge.visible { opacity: 1; }

.rec-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--red);
  animation: blink 1s ease-in-out infinite;
}

@keyframes blink {
  0%,100% { opacity: 1; }
  50% { opacity: 0.15; }
}

.rep-counter {
  font-size: 40px;
  font-weight: 900;
  color: #fff;
  font-family: var(--mono);
  text-shadow: 0 2px 20px rgba(0,0,0,0.8);
  opacity: 0;
  transition: opacity 0.3s;
}

.rep-counter.visible { opacity: 1; }

.cam-bottom {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 12px 14px;
  background: linear-gradient(0deg, rgba(0,0,0,0.85) 0%, transparent 100%);
  pointer-events: none;
}

.feedback-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 10px;
  min-height: 28px;
}

.chip {
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 11px;
  font-weight: 700;
  font-family: var(--font);
  animation: chipIn 0.3s ease;
}

@keyframes chipIn {
  from { transform: translateY(6px); opacity: 0; }
  to   { transform: translateY(0);   opacity: 1; }
}

.chip-error {
  background: rgba(255,85,85,0.2);
  border: 1px solid rgba(255,85,85,0.5);
  color: #FF8888;
}

.chip-good {
  background: rgba(0,200,150,0.15);
  border: 1px solid rgba(0,200,150,0.4);
  color: var(--green);
}

.chip-info {
  background: rgba(108,92,231,0.2);
  border: 1px solid rgba(108,92,231,0.4);
  color: #A89BFF;
}

.angles-row {
  display: flex;
  gap: 16px;
}

.angle-item { text-align: center; }

.angle-val {
  font-size: 18px;
  font-weight: 700;
  font-family: var(--mono);
  color: #fff;
  display: block;
}

.angle-val.ok   { color: var(--green); }
.angle-val.warn { color: var(--amber); }
.angle-val.bad  { color: var(--red); }

.angle-lbl {
  font-size: 9px;
  color: rgba(255,255,255,0.4);
  display: block;
  margin-top: 1px;
}

/* Corner guides */
.corner-guide {
  position: absolute;
  width: 28px; height: 28px;
  border-color: rgba(108,92,231,0.5);
  border-style: solid;
}
.corner-guide.tl { top: 12px; right: 12px; border-width: 2px 0 0 2px; border-radius: 6px 0 0 0; }
.corner-guide.tr { top: 12px; left: 12px;  border-width: 2px 2px 0 0; border-radius: 0 6px 0 0; }
.corner-guide.bl { bottom: 12px; right: 12px; border-width: 0 0 2px 2px; border-radius: 0 0 0 6px; }
.corner-guide.br { bottom: 12px; left: 12px;  border-width: 0 2px 2px 0; border-radius: 0 0 6px 0; }

/* Progress bar */
.progress-bar-wrap {
  margin-top: 14px;
}

.progress-track {
  height: 5px;
  background: rgba(255,255,255,0.07);
  border-radius: 5px;
  overflow: hidden;
  margin-bottom: 6px;
}

.progress-fill {
  height: 100%;
  border-radius: 5px;
  background: linear-gradient(90deg, var(--purple), var(--teal));
  transition: width 0.4s ease;
  width: 0%;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--text3);
  font-family: var(--mono);
}

/* Controls */
.controls {
  display: flex;
  gap: 12px;
  margin-top: 14px;
}

.btn {
  flex: 1;
  padding: 13px;
  border-radius: 14px;
  border: none;
  font-family: var(--font);
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
}

.btn:active { transform: scale(0.97); }

.btn-primary {
  background: linear-gradient(135deg, var(--purple), var(--teal));
  color: #fff;
}

.btn-secondary {
  background: var(--surface2);
  color: var(--text2);
  border: 1px solid var(--border);
}

.btn-danger {
  background: rgba(255,85,85,0.15);
  color: var(--red);
  border: 1px solid rgba(255,85,85,0.3);
}

/* Exercise selector */
.exercise-selector {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 14px;
}

.ex-btn {
  padding: 10px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--surface2);
  color: var(--text2);
  font-family: var(--font);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: all 0.2s;
}

.ex-btn:hover, .ex-btn.active {
  border-color: var(--purple);
  color: #fff;
  background: rgba(108,92,231,0.15);
}

.ex-btn.active {
  box-shadow: 0 0 0 1px var(--purple);
}

/* ===== SIDEBAR ===== */
.sidebar { display: flex; flex-direction: column; gap: 14px; }

.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 16px;
}

.card-title {
  font-size: 11px;
  color: var(--text3);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 14px;
  font-family: var(--mono);
}

/* Score ring */
.score-wrap {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 14px;
}

.score-ring-svg { flex-shrink: 0; }

.score-info { flex: 1; }

.score-num {
  font-size: 36px;
  font-weight: 900;
  color: #fff;
  font-family: var(--mono);
  line-height: 1;
}

.score-label {
  font-size: 11px;
  color: var(--text2);
  margin-top: 2px;
}

/* Metric rows */
.metric-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.metric-row:last-child { border-bottom: none; }

.metric-name {
  font-size: 12px;
  color: var(--text2);
  display: flex;
  align-items: center;
  gap: 6px;
}

.metric-val {
  font-size: 13px;
  font-weight: 700;
  font-family: var(--mono);
  color: #fff;
}

/* Perf bars */
.perf-bar-wrap { margin-bottom: 10px; }

.perf-bar-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 5px;
}

.perf-bar-name { font-size: 11px; color: var(--text2); }
.perf-bar-pct  { font-size: 11px; font-family: var(--mono); color: #fff; font-weight: 700; }

.perf-track {
  height: 5px;
  background: rgba(255,255,255,0.06);
  border-radius: 5px;
  overflow: hidden;
}

.perf-fill {
  height: 100%;
  border-radius: 5px;
  transition: width 0.6s ease;
}

.perf-fill.good { background: linear-gradient(90deg, var(--purple), var(--green)); }
.perf-fill.warn { background: linear-gradient(90deg, var(--red), var(--amber)); }

/* Error log */
.error-log {
  max-height: 180px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.error-log::-webkit-scrollbar { width: 3px; }
.error-log::-webkit-scrollbar-track { background: transparent; }
.error-log::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

.log-item {
  display: flex;
  gap: 8px;
  padding: 8px 10px;
  border-radius: 10px;
  font-size: 11px;
  line-height: 1.5;
  animation: logIn 0.3s ease;
}

@keyframes logIn {
  from { transform: translateX(-6px); opacity: 0; }
  to   { transform: translateX(0);    opacity: 1; }
}

.log-error {
  background: rgba(255,85,85,0.08);
  border: 1px solid rgba(255,85,85,0.15);
  color: rgba(255,130,130,0.9);
}

.log-good {
  background: rgba(0,200,150,0.07);
  border: 1px solid rgba(0,200,150,0.15);
  color: rgba(0,200,150,0.9);
}

.log-time {
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text3);
  flex-shrink: 0;
  margin-top: 1px;
}

/* Stats grid */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.stat-pill {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px 10px;
  text-align: center;
}

.stat-val {
  font-size: 22px;
  font-weight: 900;
  color: #fff;
  font-family: var(--mono);
  display: block;
}

.stat-lbl {
  font-size: 10px;
  color: var(--text3);
  display: block;
  margin-top: 2px;
}

/* Tip box */
.tip-box {
  background: rgba(108,92,231,0.1);
  border: 1px solid rgba(108,92,231,0.2);
  border-radius: 12px;
  padding: 12px;
  font-size: 12px;
  color: rgba(170,160,255,0.9);
  line-height: 1.6;
  display: flex;
  gap: 8px;
}

.tip-icon { flex-shrink: 0; font-size: 16px; }

/* empty state */
.empty-log {
  text-align: center;
  color: var(--text3);
  font-size: 12px;
  padding: 20px 0;
}
</style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <div class="logo">
    <div class="logo-icon">🏋️</div>
    <span class="logo-text">AI Fitness Coach</span>
  </div>
  <div class="header-status">
    <div class="status-dot" id="statusDot"></div>
    <span id="statusText">جاهز</span>
  </div>
</header>

<!-- MAIN -->
<div class="main">

  <!-- CAMERA COLUMN -->
  <div class="camera-col">

    <!-- Camera -->
    <div class="camera-wrap">
      <!-- Corners -->
      <div class="corner-guide tl"></div>
      <div class="corner-guide tr"></div>
      <div class="corner-guide bl"></div>
      <div class="corner-guide br"></div>

      <video id="videoElement" playsinline autoplay muted></video>
      <canvas id="outputCanvas"></canvas>

      <div class="camera-placeholder" id="placeholder">
        <div class="camera-placeholder-icon">📷</div>
        <p>اضغط "تشغيل الكاميرا" لبدء كشف حركة جسمك بالذكاء الاصطناعي</p>
      </div>

      <!-- Top overlay -->
      <div class="cam-top">
        <div class="rec-badge" id="recBadge">
          <div class="rec-dot"></div>
          LIVE AI
        </div>
        <div class="rep-counter" id="repCounter">0</div>
      </div>

      <!-- Bottom overlay -->
      <div class="cam-bottom">
        <div class="feedback-chips" id="feedbackChips"></div>
        <div class="angles-row" id="anglesRow" style="display:none;">
          <div class="angle-item">
            <span class="angle-val" id="angleKneeL">—</span>
            <span class="angle-lbl">ركبة يسار</span>
          </div>
          <div class="angle-item">
            <span class="angle-val" id="angleKneeR">—</span>
            <span class="angle-lbl">ركبة يمين</span>
          </div>
          <div class="angle-item">
            <span class="angle-val" id="angleHip">—</span>
            <span class="angle-lbl">الورك</span>
          </div>
          <div class="angle-item">
            <span class="angle-val" id="angleElbow">—</span>
            <span class="angle-lbl">الكوع</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Progress -->
    <div class="progress-bar-wrap">
      <div class="progress-track">
        <div class="progress-fill" id="progressFill"></div>
      </div>
      <div class="progress-labels">
        <span id="progressLabel">تكرار 0 / 10</span>
        <span id="setLabel">جولة 1 / 3</span>
      </div>
    </div>

    <!-- Controls -->
    <div class="controls">
      <button class="btn btn-primary" id="startBtn" onclick="startCamera()">▶ تشغيل الكاميرا</button>
      <button class="btn btn-secondary" id="pauseBtn" onclick="togglePause()" disabled>⏸ إيقاف مؤقت</button>
      <button class="btn btn-danger" id="stopBtn" onclick="stopCamera()" disabled>⏹ إيقاف</button>
    </div>

    <!-- Exercise selector -->
    <div class="exercise-selector">
      <button class="ex-btn active" id="ex-squat" onclick="setExercise('squat')">🦵 سكوات</button>
      <button class="ex-btn" id="ex-pushup" onclick="setExercise('pushup')">💪 ضغط</button>
      <button class="ex-btn" id="ex-lunge" onclick="setExercise('lunge')">🏃 لانج</button>
      <button class="ex-btn" id="ex-deadlift" onclick="setExercise('deadlift')">🏋️ ديدليفت</button>
    </div>
  </div>

  <!-- SIDEBAR -->
  <div class="sidebar">

    <!-- Score -->
    <div class="card">
      <div class="card-title">الأداء الكلي</div>
      <div class="score-wrap">
        <svg class="score-ring-svg" width="80" height="80" viewBox="0 0 80 80">
          <circle cx="40" cy="40" r="34" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="7"/>
          <circle cx="40" cy="40" r="34" fill="none" stroke="url(#sg)" stroke-width="7"
            stroke-dasharray="213.6" stroke-dashoffset="213.6"
            id="scoreCircle" stroke-linecap="round" transform="rotate(-90 40 40)"/>
          <defs>
            <linearGradient id="sg" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#6C5CE7"/>
              <stop offset="100%" stop-color="#00CEC9"/>
            </linearGradient>
          </defs>
        </svg>
        <div class="score-info">
          <div class="score-num" id="scoreNum">—</div>
          <div class="score-label">نقطة من 100</div>
          <div style="margin-top:6px; font-size:11px; color:var(--text3);" id="scoreMsg">لم يبدأ التمرين</div>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-pill">
          <span class="stat-val" id="totalReps">0</span>
          <span class="stat-lbl">تكرار</span>
        </div>
        <div class="stat-pill">
          <span class="stat-val" id="totalSets">0</span>
          <span class="stat-lbl">جولات</span>
        </div>
        <div class="stat-pill">
          <span class="stat-val" id="totalErrors">0</span>
          <span class="stat-lbl">أخطاء</span>
        </div>
        <div class="stat-pill">
          <span class="stat-val" id="elapsedTime">0:00</span>
          <span class="stat-lbl">وقت</span>
        </div>
      </div>
    </div>

    <!-- Performance -->
    <div class="card">
      <div class="card-title">تفاصيل الأداء</div>

      <div class="perf-bar-wrap">
        <div class="perf-bar-header">
          <span class="perf-bar-name">وضع الظهر</span>
          <span class="perf-bar-pct" id="pctBack">—</span>
        </div>
        <div class="perf-track"><div class="perf-fill good" id="barBack" style="width:0%"></div></div>
      </div>

      <div class="perf-bar-wrap">
        <div class="perf-bar-header">
          <span class="perf-bar-name">عمق الحركة</span>
          <span class="perf-bar-pct" id="pctDepth">—</span>
        </div>
        <div class="perf-track"><div class="perf-fill good" id="barDepth" style="width:0%"></div></div>
      </div>

      <div class="perf-bar-wrap">
        <div class="perf-bar-header">
          <span class="perf-bar-name">وضع المفاصل</span>
          <span class="perf-bar-pct" id="pctJoint">—</span>
        </div>
        <div class="perf-track"><div class="perf-fill good" id="barJoint" style="width:0%"></div></div>
      </div>

      <div class="perf-bar-wrap">
        <div class="perf-bar-header">
          <span class="perf-bar-name">التوازن</span>
          <span class="perf-bar-pct" id="pctBalance">—</span>
        </div>
        <div class="perf-track"><div class="perf-fill good" id="barBalance" style="width:0%"></div></div>
      </div>
    </div>

    <!-- Log -->
    <div class="card">
      <div class="card-title">سجل التغذية الراجعة</div>
      <div class="error-log" id="errorLog">
        <div class="empty-log">سيظهر هنا ملاحظات المدرب الذكي أثناء التمرين</div>
      </div>
    </div>

    <!-- Tip -->
    <div class="tip-box">
      <div class="tip-icon">💡</div>
      <div id="tipText">اختر تمرينك وشغّل الكاميرا. سيحلل الذكاء الاصطناعي حركتك ويعطيك ملاحظات فورية.</div>
    </div>

  </div>
</div>

<script>
// ============================
// STATE
// ============================
let pose = null;
let camera = null;
let isRunning = false;
let isPaused = false;

let currentExercise = 'squat';
let repCount = 0;
let setCount = 1;
let errorCount = 0;
let startTime = null;
let timerInterval = null;

let repState = 'up'; // up / down
let frameCount = 0;

// Performance accumulators
let backScores = [], depthScores = [], jointScores = [], balanceScores = [];

// Exercise tips
const tips = {
  squat: 'في السكوات: ظهرك مستقيم، الركبة لا تتجاوز القدم، انزل حتى تكون زاوية الركبة أقل من 90°.',
  pushup: 'في الضغط: جسمك يشكّل خطاً مستقيماً من الرأس للقدم، الكوع ينزل لـ 90°.',
  lunge: 'في اللانج: الركبة الأمامية فوق الكاحل، الظهر مستقيم، الركبة الخلفية قريبة من الأرض.',
  deadlift: 'في الديدليفت: ظهرك مستقيم دائماً، الحركة من الورك وليس الظهر.'
};

const repTargets = { squat: 10, pushup: 12, lunge: 10, deadlift: 8 };

// ============================
// MEDIAPIPE SETUP
// ============================
function initPose() {
  pose = new Pose({
    locateFile: (file) => `https://cdn.jsdelivr.net/npm/@mediapipe/pose/${file}`
  });

  pose.setOptions({
    modelComplexity: 1,
    smoothLandmarks: true,
    enableSegmentation: false,
    minDetectionConfidence: 0.6,
    minTrackingConfidence: 0.6
  });

  pose.onResults(onResults);
}

// ============================
// CAMERA
// ============================
async function startCamera() {
  try {
    document.getElementById('placeholder').style.display = 'none';
    document.getElementById('startBtn').disabled = true;
    document.getElementById('stopBtn').disabled = false;
    document.getElementById('pauseBtn').disabled = false;

    setStatus(true, 'يعمل');

    document.getElementById('recBadge').classList.add('visible');
    document.getElementById('repCounter').classList.add('visible');
    document.getElementById('anglesRow').style.display = 'flex';

    if (!pose) initPose();

    const video = document.getElementById('videoElement');
    const stream = await navigator.mediaDevices.getUserMedia({
      video: { width: 1280, height: 720, facingMode: 'user' }
    });
    video.srcObject = stream;
    video.onloadedmetadata = () => {
      const canvas = document.getElementById('outputCanvas');
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;
    };

    camera = new Camera(video, {
      onFrame: async () => {
        if (!isPaused && pose) {
          await pose.send({ image: video });
        }
      },
      width: 1280,
      height: 720
    });

    await camera.start();
    isRunning = true;

    startTime = Date.now();
    timerInterval = setInterval(updateTimer, 1000);

    addLog('good', '✓ الكاميرا تعمل — ابدأ تمرينك');
    updateTip();

  } catch (err) {
    document.getElementById('placeholder').style.display = 'flex';
    document.getElementById('placeholder').querySelector('p').textContent =
      'لم يتم السماح بالكاميرا. يرجى السماح بالوصول وإعادة المحاولة.';
    document.getElementById('startBtn').disabled = false;
    setStatus(false, 'خطأ في الكاميرا');
  }
}

function stopCamera() {
  if (camera) { camera.stop(); camera = null; }
  const video = document.getElementById('videoElement');
  if (video.srcObject) {
    video.srcObject.getTracks().forEach(t => t.stop());
    video.srcObject = null;
  }

  isRunning = false;
  isPaused = false;
  clearInterval(timerInterval);

  document.getElementById('startBtn').disabled = false;
  document.getElementById('stopBtn').disabled = true;
  document.getElementById('pauseBtn').disabled = true;
  document.getElementById('pauseBtn').textContent = '⏸ إيقاف مؤقت';
  document.getElementById('recBadge').classList.remove('visible');

  document.getElementById('placeholder').style.display = 'flex';
  document.getElementById('placeholder').querySelector('p').textContent =
    'اضغط "تشغيل الكاميرا" لبدء كشف حركة جسمك بالذكاء الاصطناعي';

  const canvas = document.getElementById('outputCanvas');
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  setStatus(false, 'متوقف');
  addLog('good', '✓ انتهى التمرين');
}

function togglePause() {
  isPaused = !isPaused;
  document.getElementById('pauseBtn').textContent = isPaused ? '▶ استئناف' : '⏸ إيقاف مؤقت';
  setStatus(!isPaused, isPaused ? 'متوقف مؤقتاً' : 'يعمل');
  if (isPaused) clearInterval(timerInterval);
  else timerInterval = setInterval(updateTimer, 1000);
}

// ============================
// POSE RESULTS
// ============================
function onResults(results) {
  const canvas = document.getElementById('outputCanvas');
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  if (!results.poseLandmarks) return;

  frameCount++;

  // Draw skeleton
  drawConnectors(ctx, results.poseLandmarks, POSE_CONNECTIONS, {
    color: 'rgba(108,92,231,0.5)',
    lineWidth: 2.5
  });

  drawLandmarks(ctx, results.poseLandmarks, {
    color: '#00C896',
    fillColor: 'rgba(0,200,150,0.3)',
    lineWidth: 1,
    radius: 4
  });

  const lm = results.poseLandmarks;

  // Calculate angles
  const kneeL   = calcAngle(lm[23], lm[25], lm[27]);
  const kneeR   = calcAngle(lm[24], lm[26], lm[28]);
  const hipL    = calcAngle(lm[11], lm[23], lm[25]);
  const hipR    = calcAngle(lm[12], lm[24], lm[26]);
  const elbowL  = calcAngle(lm[11], lm[13], lm[15]);
  const elbowR  = calcAngle(lm[12], lm[14], lm[16]);
  const backAng = calcAngle(lm[11], lm[23], lm[25]);

  // Update angle display
  const avgKneeL = kneeL ? Math.round(kneeL) : null;
  const avgKneeR = kneeR ? Math.round(kneeR) : null;
  const avgHip   = hipL  ? Math.round((hipL + (hipR||hipL)) / 2) : null;
  const avgElbow = elbowL? Math.round((elbowL + (elbowR||elbowL)) / 2) : null;

  setAngle('angleKneeL', avgKneeL, 90, 120);
  setAngle('angleKneeR', avgKneeR, 90, 120);
  setAngle('angleHip',   avgHip,   80, 110);
  setAngle('angleElbow', avgElbow, 80, 110);

  // Draw warning highlights
  if (kneeL && kneeL > 120) highlightJoint(ctx, lm[25], canvas.width, canvas.height, '#FF5555');
  if (kneeR && kneeR > 120) highlightJoint(ctx, lm[26], canvas.width, canvas.height, '#FF5555');

  // Exercise analysis
  analyzeExercise(lm, kneeL, kneeR, hipL, hipR, elbowL, elbowR, backAng);
}

function highlightJoint(ctx, lm, w, h, color) {
  ctx.beginPath();
  ctx.arc(lm.x * w, lm.y * h, 14, 0, 2 * Math.PI);
  ctx.strokeStyle = color;
  ctx.lineWidth = 2.5;
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(lm.x * w, lm.y * h, 6, 0, 2 * Math.PI);
  ctx.fillStyle = color;
  ctx.fill();
}

// ============================
// ANGLE CALCULATION
// ============================
function calcAngle(a, b, c) {
  if (!a || !b || !c) return null;
  const ab = { x: a.x - b.x, y: a.y - b.y };
  const cb = { x: c.x - b.x, y: c.y - b.y };
  const dot = ab.x * cb.x + ab.y * cb.y;
  const magAB = Math.sqrt(ab.x**2 + ab.y**2);
  const magCB = Math.sqrt(cb.x**2 + cb.y**2);
  if (magAB === 0 || magCB === 0) return null;
  const cos = Math.max(-1, Math.min(1, dot / (magAB * magCB)));
  return Math.acos(cos) * (180 / Math.PI);
}

function setAngle(id, val, goodMax, warnMax) {
  const el = document.getElementById(id);
  if (!val) { el.textContent = '—'; el.className = 'angle-val'; return; }
  el.textContent = val + '°';
  el.className = 'angle-val ' + (val <= goodMax ? 'ok' : val <= warnMax ? 'warn' : 'bad');
}

// ============================
// EXERCISE ANALYSIS
// ============================
function analyzeExercise(lm, kneeL, kneeR, hipL, hipR, elbowL, elbowR, backAng) {
  const chips = [];
  let backScore = 100, depthScore = 100, jointScore = 100, balanceScore = 100;
  const logThisFrame = (frameCount % 20 === 0);

  if (currentExercise === 'squat') {
    const avgKnee = kneeL && kneeR ? (kneeL + kneeR) / 2 : (kneeL || kneeR);
    const avgHip  = hipL  && hipR  ? (hipL  + hipR)  / 2 : (hipL  || hipR);

    // Rep counting
    if (avgKnee) {
      if (avgKnee < 100 && repState === 'up') {
        repState = 'down';
      } else if (avgKnee > 150 && repState === 'down') {
        repState = 'up';
        countRep();
      }
    }

    // Depth check
    if (avgKnee) {
      if (avgKnee < 90)       { chips.push({t:'انزل أكثر قليلاً', c:'info'}); depthScore = 70; }
      else if (avgKnee < 120) { chips.push({t:'✓ عمق ممتاز', c:'good'}); depthScore = 100; }
      else                    { chips.push({t:'⚠ انزل أكثر — زاوية الركبة كبيرة', c:'error'}); depthScore = 40; if(logThisFrame) addLog('error','انزل أكثر في السكوات'); }
    }

    // Back check
    if (backAng) {
      if (backAng > 160)       { chips.push({t:'✓ الظهر مستقيم', c:'good'}); backScore = 100; }
      else if (backAng > 140)  { chips.push({t:'⚠ قوّم ظهرك أكثر', c:'error'}); backScore = 60; if(logThisFrame) addLog('error','ظهرك منحنٍ — قوّمه'); }
    }

    // Balance
    if (kneeL && kneeR) {
      const diff = Math.abs(kneeL - kneeR);
      if (diff < 12) { balanceScore = 100; }
      else { balanceScore = 60; chips.push({t:'⚠ وزّع وزنك بالتساوي', c:'error'}); }
    }

    depthScores.push(depthScore);
    backScores.push(backScore);
    jointScores.push(jointScore);
    balanceScores.push(balanceScore);

  } else if (currentExercise === 'pushup') {
    const avgElbow = elbowL && elbowR ? (elbowL + elbowR) / 2 : (elbowL || elbowR);

    if (avgElbow) {
      if (avgElbow < 90 && repState === 'up') {
        repState = 'down';
      } else if (avgElbow > 160 && repState === 'down') {
        repState = 'up';
        countRep();
      }
    }

    if (avgElbow) {
      if (avgElbow < 90) { chips.push({t:'✓ نزول ممتاز', c:'good'}); depthScore = 100; }
      else if (avgElbow < 120) { chips.push({t:'انزل أكثر', c:'info'}); depthScore = 75; }
      else { chips.push({t:'⚠ الكوع لم ينزل للـ 90°', c:'error'}); depthScore = 45; if(logThisFrame) addLog('error','انزل في الضغط أكثر'); }
    }

    if (backAng) {
      if (backAng > 165) { chips.push({t:'✓ جسمك مستقيم', c:'good'}); backScore = 100; }
      else { chips.push({t:'⚠ استقم جسمك', c:'error'}); backScore = 55; if(logThisFrame) addLog('error','جسمك غير مستقيم في الضغط'); }
    }

    depthScores.push(depthScore);
    backScores.push(backScore);
    jointScores.push(jointScore);
    balanceScores.push(balanceScore);

  } else if (currentExercise === 'lunge') {
    const avgKnee = kneeL && kneeR ? Math.min(kneeL, kneeR) : (kneeL || kneeR);

    if (avgKnee) {
      if (avgKnee < 100 && repState === 'up') { repState = 'down'; }
      else if (avgKnee > 160 && repState === 'down') { repState = 'up'; countRep(); }

      if (avgKnee < 110) { chips.push({t:'✓ عمق اللانج جيد', c:'good'}); depthScore = 100; }
      else { chips.push({t:'⚠ انزل أكثر في اللانج', c:'error'}); depthScore = 55; if(logThisFrame) addLog('error','انزل أكثر في اللانج'); }
    }

    if (backAng && backAng > 160) chips.push({t:'✓ الظهر مستقيم', c:'good'});
    else if(backAng) { chips.push({t:'⚠ قوّم ظهرك', c:'error'}); backScore = 60; }

    depthScores.push(depthScore);
    backScores.push(backScore);
    jointScores.push(100);
    balanceScores.push(80);

  } else if (currentExercise === 'deadlift') {
    const avgHip = hipL && hipR ? (hipL + hipR) / 2 : (hipL || hipR);

    if (avgHip) {
      if (avgHip < 80 && repState === 'up') { repState = 'down'; }
      else if (avgHip > 160 && repState === 'down') { repState = 'up'; countRep(); }
    }

    if (backAng) {
      if (backAng > 155) { chips.push({t:'✓ الظهر صحيح', c:'good'}); backScore = 100; }
      else { chips.push({t:'⚠ الظهر منحنٍ! — خطر', c:'error'}); backScore = 30; if(logThisFrame) addLog('error','⚠ خطر — ظهرك منحنٍ في الديدليفت'); }
    }

    if (avgHip) {
      if (avgHip < 130) { chips.push({t:'✓ الحركة من الورك', c:'good'}); depthScore = 100; }
      else { chips.push({t:'⚠ انزل أكثر من الورك', c:'info'}); depthScore = 70; }
    }

    depthScores.push(depthScore);
    backScores.push(backScore);
    jointScores.push(100);
    balanceScores.push(90);
  }

  // Update chips
  if (frameCount % 3 === 0) updateChips(chips);

  // Update bars every 10 frames
  if (frameCount % 10 === 0) updatePerformance();
}

// ============================
// REP COUNTING
// ============================
function countRep() {
  repCount++;
  const target = repTargets[currentExercise] || 10;
  document.getElementById('repCounter').textContent = repCount;
  document.getElementById('totalReps').textContent = repCount;
  document.getElementById('progressLabel').textContent = `تكرار ${repCount} / ${target}`;
  document.getElementById('progressFill').style.width = Math.min(100, (repCount / target) * 100) + '%';

  if (repCount > 0 && repCount % target === 0) {
    setCount++;
    document.getElementById('totalSets').textContent = setCount - 1;
    document.getElementById('setLabel').textContent = `جولة ${setCount} / 3`;
    addLog('good', `✓ أكملت الجولة ${setCount - 1} — ${target} تكرار!`);
  }

  updateScore();
}

// ============================
// UI UPDATES
// ============================
function updateChips(chips) {
  const container = document.getElementById('feedbackChips');
  container.innerHTML = '';
  chips.slice(0, 3).forEach(chip => {
    const el = document.createElement('div');
    el.className = `chip chip-${chip.c}`;
    el.textContent = chip.t;
    container.appendChild(el);
  });
}

function updatePerformance() {
  const avg = arr => arr.length ? Math.round(arr.slice(-30).reduce((a,b)=>a+b,0) / Math.min(arr.length, 30)) : null;

  const b = avg(backScores);
  const d = avg(depthScores);
  const j = avg(jointScores);
  const bl = avg(balanceScores);

  setPerfBar('barBack',    'pctBack',    b);
  setPerfBar('barDepth',   'pctDepth',   d);
  setPerfBar('barJoint',   'pctJoint',   j);
  setPerfBar('barBalance', 'pctBalance', bl);
}

function setPerfBar(barId, pctId, val) {
  if (!val) return;
  const bar = document.getElementById(barId);
  const pct = document.getElementById(pctId);
  bar.style.width = val + '%';
  pct.textContent = val + '%';
  bar.className = 'perf-fill ' + (val >= 70 ? 'good' : 'warn');
  pct.style.color = val >= 70 ? 'var(--green)' : 'var(--red)';
}

function updateScore() {
  const avg = arr => arr.length ? Math.round(arr.slice(-20).reduce((a,b)=>a+b,0)/Math.min(arr.length,20)) : 0;
  const score = Math.round((avg(backScores) + avg(depthScores) + avg(jointScores) + avg(balanceScores)) / 4);

  document.getElementById('scoreNum').textContent = score;
  const circumference = 213.6;
  const offset = circumference - (score / 100) * circumference;
  document.getElementById('scoreCircle').style.strokeDashoffset = offset;

  const msgs = ['ابدأ التمرين 💪', 'حاول أكثر 🔧', 'جيد — استمر 👍', 'ممتاز! 🔥', 'مثالي! ⭐'];
  const idx = score < 40 ? 0 : score < 60 ? 1 : score < 75 ? 2 : score < 90 ? 3 : 4;
  document.getElementById('scoreMsg').textContent = msgs[idx];
}

function addLog(type, msg) {
  const log = document.getElementById('errorLog');
  const empty = log.querySelector('.empty-log');
  if (empty) empty.remove();

  errorCount++;
  document.getElementById('totalErrors').textContent = errorCount;

  const now = new Date();
  const time = `${now.getMinutes().toString().padStart(2,'0')}:${now.getSeconds().toString().padStart(2,'0')}`;

  const item = document.createElement('div');
  item.className = `log-item log-${type}`;
  item.innerHTML = `<span class="log-time">${time}</span><span>${msg}</span>`;

  log.insertBefore(item, log.firstChild);

  if (log.children.length > 20) log.lastChild.remove();
}

function updateTimer() {
  if (!startTime) return;
  const elapsed = Math.floor((Date.now() - startTime) / 1000);
  const m = Math.floor(elapsed / 60);
  const s = elapsed % 60;
  document.getElementById('elapsedTime').textContent = `${m}:${s.toString().padStart(2,'0')}`;
}

function setStatus(active, text) {
  document.getElementById('statusDot').className = 'status-dot' + (active ? ' active' : '');
  document.getElementById('statusText').textContent = text;
}

function setExercise(ex) {
  currentExercise = ex;
  repCount = 0;
  repState = 'up';
  document.getElementById('repCounter').textContent = '0';
  document.getElementById('progressFill').style.width = '0%';
  document.getElementById('progressLabel').textContent = `تكرار 0 / ${repTargets[ex]}`;

  document.querySelectorAll('.ex-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('ex-' + ex).classList.add('active');

  backScores = []; depthScores = []; jointScores = []; balanceScores = [];
  updateTip();
}

function updateTip() {
  document.getElementById('tipText').textContent = tips[currentExercise] || '';
}
</script>
